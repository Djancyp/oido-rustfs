{
  "name": "oido-rustfs",
  "version": "1.0.0",
  "description": "Read files from RustFS object storage and inject their text content into the LLM context.",
  "runtime": "make build",
  "mcpServers": {
    "oido-rustfs": {
      "command": "${extensionPath}/oido-rustfs-mcp",
      "args": [],
      "env": {
        "RUSTFS_BASE_URL": "${RUSTFS_BASE_URL}",
        "RUSTFS_ACCESS_KEY": "${RUSTFS_ACCESS_KEY}",
        "RUSTFS_SECRET_KEY": "${RUSTFS_SECRET_KEY}",
        "RUSTFS_BUCKET": "${RUSTFS_BUCKET}"
      }
    }
  },
  "contextFileName": "OIDO.md",
  "excludeTools": [],
  "settings": [
    {
      "name": "RUSTFS_BASE_URL",
      "description": "RustFS server base URL (e.g. http://localhost:9000)",
      "defaultValue": "",
      "type": "string"
    },
    {
      "name": "RUSTFS_ACCESS_KEY",
      "description": "RustFS access key",
      "defaultValue": "",
      "type": "string"
    },
    {
      "name": "RUSTFS_SECRET_KEY",
      "description": "RustFS secret key",
      "defaultValue": "",
      "type": "string"
    },
    {
      "name": "RUSTFS_BUCKET",
      "description": "Allowed buckets (comma-separated). Default bucket is first in list.",
      "defaultValue": "chat-attachments",
      "type": "string"
    }
  ]
}
